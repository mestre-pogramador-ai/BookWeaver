# ============================================
# BOOKWEAVER - .gitignore
# ============================================

# --------------------------------------------
# Python
# --------------------------------------------
# Bytecode compilado
__pycache__/
*.py[cod]
*$py.class
*.so

# Ambientes virtuais
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# Distribuição
dist/
build/
*.egg-info/
*.egg
*.whl

# Cobertura de testes
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.pytest_cache/

# Perfilamento
*.prof

# --------------------------------------------
# IDE e Editores
# --------------------------------------------
# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Eclipse
.project
.pydevproject
.settings/

# Spyder
.spyderproject
.spyproject

# --------------------------------------------
# Sistema Operacional
# --------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp

# Linux
*~
.directory
.Trash-*

# --------------------------------------------
# BookWeaver - Arquivos específicos
# --------------------------------------------
# Projetos de eBook (gerados pelo usuário)
*.bwproj
*.bwproj.bak

# Exportações temporárias
exports/temp/
*.epub.tmp
*.mobi.tmp

# Logs
*.log
logs/
debug.log

# Backups automáticos
backups/
*.bak
*.backup
~$*.docx
~$*.odt

# Cache do BookWeaver
.bookweaver_cache/
.cache/

# Screenshots temporários
screenshots/temp/

# --------------------------------------------
# Dados sensíveis e configurações
# --------------------------------------------
# Variáveis de ambiente
.env
.env.local
.env.production
.env.development

# Configurações pessoais
config.local.py
settings.local.py
secrets.py

# Chaves API e credenciais
*.key
*.pem
*.cert
credentials.json
client_secret.json

# --------------------------------------------
# Arquivos de teste e exemplo
# --------------------------------------------
# eBooks de teste (exceto exemplos oficiais)
test_ebooks/*
!test_ebooks/exemplo_oficial/

# Output de testes
test-output/
tests/output/
*.test.epub

# --------------------------------------------
# Dependências e pacotes
# --------------------------------------------
# Node (se usar ferramentas frontend)
node_modules/
package-lock.json

# Pandoc (conversões temporárias)
*.pandoc.tmp

# KindleGen (arquivos temporários)
kindlegen/
*.mobi.tmp

# --------------------------------------------
# Outros
# --------------------------------------------
# Arquivos ZIP
*.zip
*.tar.gz
*.rar

# Banco de dados
*.db
*.sqlite
*.sqlite3

# PDFs gerados (exceto documentação)
*.pdf
!docs/*.pdf

# Arquivos de mídia grandes (use Git LFS)
*.mp4
*.mp3
*.wav
*.mov
*.avi
